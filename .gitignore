# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment Variables ─────────────────────────────────────────────────────
# Never commit secrets — use .env.example as the template
.env
.env.local
.env.development
.env.production
.env.staging
dems-backend/.env
dems-frontend/.env

# ── Build Output ──────────────────────────────────────────────────────────────
dist/
build/
out/
dems-backend/dist/

# ── Vite ──────────────────────────────────────────────────────────────────────
.vite/
dems-frontend/.vite/

# ── Prisma ────────────────────────────────────────────────────────────────────
# Keep schema.prisma and migrations — exclude generated client
dems-backend/node_modules/.prisma/
dems-backend/prisma/migrations/*.sql.bak

# ── Uploads ───────────────────────────────────────────────────────────────────
# User-uploaded files should not be in version control
dems-backend/uploads/
!dems-backend/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor & IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.psd
*.sketch
*.backup
*.back
.cache/
.temp/
tmp/
